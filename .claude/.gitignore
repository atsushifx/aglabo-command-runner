# default all files are denies
*

# gitignore = thisfile
!.git*

# settings
!settings.json

## claude
#
# plugins
!plugins/
!plugins/*

# agent
!agents/
!agents/*

# skills
!skills/
!skills/**
!skills/**/
!skills/**/*

